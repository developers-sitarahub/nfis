# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.key
*.cert
*.crt
*.sqlite
*.sqlite3
*.db

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# env files (safely ignore all local and actual environment files)
.env
.env*.local
.env.development
.env.test
.env.production
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# IDEs and Editors
.idea/
.vscode/
*.swp
*.swo

# package manager configs
.npmrc
.yarnrc